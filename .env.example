# occultation-details — environment variable template
# Copy this file to .env and fill in your own values.
# .env is git-ignored and must NEVER be committed.

# Google Sheets spreadsheet ID (the long string from the spreadsheet URL)
OCCULTATION_SPREADSHEET_ID=your-spreadsheet-id-here

# Path to the Google service account JSON key file
# Download this from the Google Cloud Console → IAM & Admin → Service Accounts
GOOGLE_SERVICE_ACCOUNT_KEY=service_account.json
